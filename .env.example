# Ruta Colombia -- environment variables (example)
# Copy to .env.local for local development. Set via Netlify UI for production.

# ---- Travelpayouts affiliate marker ----------------------------------------
# Required for the AffiliateCTA component (hotels / flights / car rentals /
# tours). Without this var the component renders nothing -- see
# src/components/AffiliateCTA.tsx which returns null when the marker is empty
# (this is the documented safe-default; do NOT replace with a literal string).
# Obtain from: https://www.travelpayouts.com/ (after account activation).
NEXT_PUBLIC_TRAVELPAYOUTS_MARKER=

# ---- Google AdSense publisher id -------------------------------------------
# Loaded by the site-wide ads loader (see scripts/ads.js). The publisher id
# is public-by-design per Google's docs, but kept env-driven so non-prod
# previews don't trigger live ad serving.
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-2469196723812841
